        "from prophet import Prophet\n",
        "import numpy as np\n",
        "\n",
        "# Use WEEKLY instead of daily â much cleaner signal\n",
        "weekly = df.groupby(pd.Grouper(key='Order Date', freq='W'))['Sales'].sum().reset_index()\n",
        "weekly.columns = ['ds', 'y']\n",
        "weekly = weekly[weekly['y'] > 0]  # remove zero weeks\n",
        "\n",
        "model = Prophet(yearly_seasonality=True, weekly_seasonality=False, interval_width=0.90)\n",
        "model.fit(weekly)\n",
        "\n",
        "future = model.make_future_dataframe(periods=13, freq='W')  # 13 weeks = 90 days\n",
        "forecast = model.predict(future)\n",
        "\n",
        "fig = model.plot(forecast)\n",
        "plt.title('Revenue Forecast â Next 90 Days')\n",
        "plt.savefig('forecast.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# MAPE\n",
        "merged = weekly.merge(forecast[['ds','yhat']], on='ds')\n",
        "mape = np.mean(np.abs((merged['y'] - merged['yhat']) / merged['y'])) * 100\n",
        "print(f\"MAPE: {mape:.2f}%  â paste this into your resume!\")\n",
        "\n",
        "forecast[['ds','yhat','yhat_lower','yhat_upper']].to_csv('forecast_output.csv', index=False)\n",
        "print(\"forecast_output.csv saved!\")"
